               <rdf:value>http://arxiv.org/abs/2505.10649</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-22 15:16:58</dcterms:dateSubmitted>
        <dc:description>arXiv:2505.10649</dc:description>
    </bib:Article>
