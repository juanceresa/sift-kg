            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-26 16:33:17</dcterms:dateSubmitted>
        <dc:description>arXiv:2303.03793 [physics]</dc:description>
    </bib:Article>
