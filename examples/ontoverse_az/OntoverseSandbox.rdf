            <dcterms:URI>
               <rdf:value>http://arxiv.org/abs/2505.05702</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-27 15:35:23</dcterms:dateSubmitted>
        <dc:description>arXiv:2505.05702 [cs]</dc:description>
        <bib:pages>131823-131838</bib:pages>
    </bib:Article>
