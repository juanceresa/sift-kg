            <dcterms:URI>
               <rdf:value>http://arxiv.org/abs/2509.22352</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-27 14:09:39</dcterms:dateSubmitted>
        <dc:description>arXiv:2509.22352 [cs]</dc:description>
    </bib:Article>
