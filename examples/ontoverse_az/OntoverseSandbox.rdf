               <rdf:value>http://arxiv.org/abs/2601.05242</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-26 16:51:28</dcterms:dateSubmitted>
        <dc:description>arXiv:2601.05242 [cs]</dc:description>
