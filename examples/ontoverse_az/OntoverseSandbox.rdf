            <dcterms:URI>
               <rdf:value>http://arxiv.org/abs/2510.09121</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-26 16:41:57</dcterms:dateSubmitted>
        <dc:description>arXiv:2510.09121 [cs]</dc:description>
    </bib:Article>
