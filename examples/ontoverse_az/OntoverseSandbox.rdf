               <rdf:value>http://arxiv.org/abs/2511.11452</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-27 10:43:33</dcterms:dateSubmitted>
        <dc:description>arXiv:2511.11452 [q-bio]</dc:description>
    </bib:Article>
