               <rdf:value>http://arxiv.org/abs/2210.05175</rdf:value>
            </dcterms:URI>
        </dc:identifier>
        <dcterms:dateSubmitted>2026-01-26 16:45:17</dcterms:dateSubmitted>
        <dc:description>arXiv:2210.05175 [cs]</dc:description>
    </bib:Article>
